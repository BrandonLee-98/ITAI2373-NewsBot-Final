# 📊 Notebook 01: Enhanced News Data Exploration
# This notebook demonstrates the initial stage of the **Module A: Advanced Content Analysis Engine**[cite: 19]. 
# We will perform:
# 1. Data loading and validation.
# 2. Text cleaning using the project's custom preprocessor.
# 3. Statistical analysis of text length and word frequency.

# Section 2: Code - Setup & Imports

import os
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from wordcloud import WordCloud

# Import your project's custom processor (assumes repo is cloned)
from src.data_processing.text_preprocessor import TextPreprocessor

# Initialize preprocessor
preprocessor = TextPreprocessor()

# Create a sample dataset for demonstration
data = {
    'text': [
        "OpenAI released a new GPT model today focusing on reasoning.",
        "The Supreme Court is reviewing the new legal framework for digital liability.",
        "Markets rallied as the Federal Reserve kept interest rates steady.",
        "New breakthroughs in cancer research were published in the Science journal.",
        "El mercado de valores cerró al alza hoy tras el anuncio oficial."
    ],
    'category': ['Tech', 'Legal', 'Finance', 'Science', 'Finance']
}
df = pd.DataFrame(data)
print("✅ Dataset Loaded.")

# Section 3: Code - Cleaning & Exploration

# Apply custom preprocessing [cite: 44]
df['clean_text'] = df['text'].apply(preprocessor.clean)

# Feature Engineering: Calculate sentence and word lengths [cite: 339]
df['word_count'] = df['text'].apply(lambda x: len(x.split()))
df['char_count'] = df['text'].apply(len)

# Visualize Distribution
plt.figure(figsize=(10, 5))
sns.histplot(df['word_count'], bins=5, kde=True, color='blue')
plt.title('Distribution of Article Word Counts')
plt.xlabel('Words')
plt.ylabel('Frequency')
plt.show()

print("✅ Statistical Analysis Complete.")

# Section 4: Code - Word Cloud Visualization

# Generate a WordCloud to visualize theme density [cite: 126]
all_text = " ".join(df['clean_text'])
wordcloud = WordCloud(width=800, height=400, background_color='white').generate(all_text)

plt.figure(figsize=(10, 5))
plt.imshow(wordcloud, interpolation='bilinear')
plt.axis('off')
plt.title('Dominant Keywords in News Corpus')
plt.show()
